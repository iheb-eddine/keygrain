# Keygrain server configuration
# Copy to .env and fill in values. This file is NOT tracked in git.

# Domain
DOMAIN=keygrain.com

# Server
APP_PORT=9860
APP_DIR=/opt/keygrain

# SSL
CERTBOT_EMAIL=admin@keygrain.com

# Rate limiting (must match nginx header)
KEYGRAIN_RATE_LIMIT_TRUSTED_HEADER=X-Real-IP

# Deploy user (for CI SSH access)
DEPLOY_USER=deploy
