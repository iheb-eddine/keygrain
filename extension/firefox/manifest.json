{
  "manifest_version": 2,
  "name": "Keygrain",
  "version": "1.0.0",
  "description": "Deterministic password generator — no storage, no sync, no trust.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Keygrain popup"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": "script-src 'self'; object-src 'none'",
  "browser_specific_settings": {
    "gecko": {
      "id": "keygrain@secbytech.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "is_exempt": true,
        "reason": "Keygrain does not collect, store, or transmit any user data. All computation is local."
      }
    }
  }
}
