{
  "manifest_version": 2,
  "name": "Keygrain",
  "version": "0.9.0",
  "description": "Deterministic password generator with encrypted sync. Your master password never leaves your device.",
  "permissions": [
    "activeTab",
    "alarms",
    "contextMenus",
    "storage",
    "tabs",
    "https://keygrain.com/*"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "scripts": ["lib/hash-wasm-argon2.js", "keygrain.js", "sync.js", "background.js"]
  },
  "commands": {
    "fill_credentials": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Fill credentials for current site"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": "script-src 'self' 'wasm-unsafe-eval'; object-src 'none'",
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@keygrain.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
