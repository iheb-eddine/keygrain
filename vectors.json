  "_algorithm": "strengthened = Argon2id(secret, salt='keygrain-strengthen:'+lowercase(email), t=3, m=65536, p=1, len=32); message = lowercase(site) + ':' + lowercase(email) + ':' + str(length) + ':' + str(counter); key = HMAC-SHA256(strengthened, message)",
